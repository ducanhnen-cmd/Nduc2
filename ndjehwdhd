-- ========== FIX LAG ==========
local fixLagEnabled = true

local function applyFixLag()
    if not fixLagEnabled then return end
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 1000
        Lighting.FogStart = 500
        Lighting.Brightness = 1
        Lighting.ClockTime = 12
        local settings = UserSettings()
        local gameSettings = settings:GetService("UserGameSettings")
        gameSettings.EnvironmentalQuality = Enum.EnvironmentalQuality.Low
        Workspace.Terrain.WaterWaveSize = 0
        Workspace.CurrentCamera.FieldOfView = 70
    end)
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") then
            pcall(function() v.Enabled = false end)
        end
    end
end

local function startFixLagLoop()
    task.spawn(function()
        while fixLagEnabled do
            applyFixLag()
            task.wait(5)
        end
    end)
end
startFixLagLoop()

