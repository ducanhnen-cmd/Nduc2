local function makeDropdown(parent, text, options, default, callback)
    local row = new("Frame", {Parent = parent, Size = UDim2.new(1,0,0,60), BackgroundColor3 = Color3.fromRGB(35,35,35)})
    new("UICorner", {Parent = row, CornerRadius = UDim.new(0,8)})
    
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,8), Size = UDim2.new(1,-24,0,18), TextXAlignment = Enum.TextXAlignment.Left})
    
    local btn = new("TextButton", {Parent = row, Size = UDim2.new(1,-24,0,32), Position = UDim2.new(0,12,0,24), BackgroundColor3 = Color3.fromRGB(55,55,55), Text = default or options[1], Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, AutoButtonColor = false})
    new("UICorner", {Parent = btn, CornerRadius = UDim.new(0,6)})
    
    local menu = new("Frame", {Parent = row, Size = UDim2.new(1,-24,0,#options*32), Position = UDim2.new(0,12,0,56), BackgroundColor3 = Color3.fromRGB(45,45,45), Visible = false})
    new("UICorner", {Parent = menu, CornerRadius = UDim.new(0,6)})
    
    for i, opt in ipairs(options) do
        local optBtn = new("TextButton", {Parent = menu, Size = UDim2.new(1,-8,0,30), Position = UDim2.new(0,4,0,(i-1)*32), BackgroundTransparency = 1, Text = opt, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = TXT, AutoButtonColor = false})
        optBtn.MouseButton1Click:Connect(function()
            btn.Text = opt
            menu.Visible = false
            if callback then pcall(callback, opt) end
        end)
    end
    
    btn.MouseButton1Click:Connect(function()
        menu.Visible = not menu.Visible
        task.delay(5, function() menu.Visible = false end)
    end)
    
    return {Row = row, Get = function() return btn.Text end}
end

-- HÀM TẠO SLIDER
local function makeSlider(parent, text, minv, maxv, default, callback)
    local row = new("Frame", {Parent = parent, Size = UDim2.new(1,0,0,70), BackgroundColor3 = Color3.fromRGB(35,35,35)})
    new("UICorner", {Parent = row, CornerRadius = UDim.new(0,8)})
    
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,8), Size = UDim2.new(1,-24,0,20), TextXAlignment = Enum.TextXAlignment.Left})
    
    local valueLabel = new("TextLabel", {Parent = row, Text = tostring(default), Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = ACCENT, BackgroundTransparency = 1, Position = UDim2.new(1,-50,0,8), Size = UDim2.new(0,40,0,20), TextXAlignment = Enum.TextXAlignment.Right})
    
    local bar = new("Frame", {Parent = row, Size = UDim2.new(1,-80,0,6), Position = UDim2.new(0,12,0,45), BackgroundColor3 = Color3.fromRGB(60,60,60)})
    new("UICorner", {Parent = bar, CornerRadius = UDim.new(0,3)})
    
    local frac = (default - minv) / (maxv - minv)
    local fill = new("Frame", {Parent = bar, Size = UDim2.new(frac,0,1,0), BackgroundColor3 = ACCENT})
    new("UICorner", {Parent = fill, CornerRadius = UDim.new(0,3)})
    
    local knob = new("Frame", {Parent = bar, Size = UDim2.new(0,14,0,14), Position = UDim2.new(frac,-7,0.5,-7), BackgroundColor3 = Color3.fromRGB(245,245,245)})
    new("UICorner", {Parent = knob, CornerRadius = UDim.new(1,0)})
    
    local dragging = false
    
    local function updateValue(input)
        local x = math.clamp(input.Position.X - bar.AbsolutePosition.X, 0, bar.AbsoluteSize.X)
        local newFrac = x / bar.AbsoluteSize.X
        local val = math.floor(minv + (maxv - minv) * newFrac)
        fill.Size = UDim2.new(newFrac,0,1,0)
        knob.Position = UDim2.new(newFrac,-7,0.5,-7)
        valueLabel.Text = tostring(val)
        distanceFarm = val
        if callback then callback(val) end
    end
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local con
            con = UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
                    updateValue(input)
                end
            end)
            knob.InputEnded:Connect(function()
                dragging = false
                con:Disconnect()
            end)
        end
    end)
    
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateValue(input)
            dragging = true
        end
    end)
    
    return {Row = row}
end

