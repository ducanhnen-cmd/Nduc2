local function getServerUptime()
    local uptime = Workspace.DistributedGameTime or 0
    return string.format("%02d:%02d:%02d", math.floor(uptime/3600), math.floor((uptime%3600)/60), math.floor(uptime%60))
end

local function scanForKeyword(keywords)
    for _, keyword in ipairs(keywords) do
        if Workspace:FindFirstChild(keyword) then return true end
    end
    return false
end

local function makeStatusRow(parent, text)
    local row = new("Frame", {Parent = parent, Size = UDim2.new(1,0,0,38), BackgroundColor3 = PANEL})
    new("UICorner", {Parent = row, CornerRadius = UDim.new(0,6)})
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.GothamSemibold, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,0), Size = UDim2.new(0.75,0,1,0), TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Center})
    local statusIcon = new("TextLabel", {Parent = row, Text = "⏳", Font = Enum.Font.GothamBold, TextSize = 18, TextColor3 = YELLOW, BackgroundTransparency = 1, Position = UDim2.new(0.88,0,0,0), Size = UDim2.new(0.12,0,1,0), TextXAlignment = Enum.TextXAlignment.Center, TextYAlignment = Enum.TextYAlignment.Center})
    return {Row = row, StatusIcon = statusIcon}
end

local function updateAllStatus()
    if serverTimeLabel then
        serverTimeLabel.Text = "⏱️ Server Uptime: " .. getServerUptime()
    end
    for _, item in ipairs(statusItems) do
        local row = statusRows[item.Name]
        if row then
            if scanForKeyword(item.Keywords) then
                row.StatusIcon.Text = "✅"
                row.StatusIcon.TextColor3 = GREEN
            else
                row.StatusIcon.Text = "❌"
                row.StatusIcon.TextColor3 = RED
            end
        end
    end
end

