-- ========== FAST ATTACK CỐT LÕI ==========
local RS = ReplicatedStorage
local N, C, hit, atk = nil, nil, nil, nil

local function setupFastAttack()
    pcall(function()
        N = require(RS.Modules.Net)
        C = require(RS.Modules.CombatUtil)
        hit = N:RemoteEvent("RegisterHit", true)
        atk = RS.Modules.Net["RE/RegisterAttack"]
    end)
end
setupFastAttack()

local fastAttackEnabled = true
local distanceFarm = 50
local selectedWeapon = "Melee"

local function equipWeapon(weaponType)
    selectedWeapon = weaponType
    print("[Chọn Vũ Khí] Đã chọn:", weaponType)
end

local function startFastAttack()
    task.spawn(function()
        while fastAttackEnabled do
            task.wait()
            local p = Players.LocalPlayer
            local c = p.Character if not c then continue end
            local r = c:FindFirstChild("HumanoidRootPart")
            local t = c:FindFirstChildOfClass("Tool")
            if not (r and t) then continue end
            local id = tostring(p.UserId):sub(2,4) .. tostring(coroutine.running()):sub(11,15)
            local didy = false
            
            local enemies = Workspace:FindFirstChild("Enemies")
            if enemies then
                for _, m in ipairs(enemies:GetChildren()) do
                    local h = m:FindFirstChild("HumanoidRootPart")
                    local u = m:FindFirstChild("Humanoid")
                    if h and u and u.Health > 0 and (h.Position - r.Position).Magnitude <= distanceFarm then
                        if not didy and atk then pcall(function() atk:FireServer() end) didy = true end
                        if hit then pcall(function() hit:FireServer(h, {{m, h}}, nil, nil, id) end) end
                    end
                end
            end
        end
    end)
end
startFastAttack()

-- ========== BRING MOB (KÉO QUÁI) ==========
local bringMobEnabled = false
local bringRange = 100
local bringDistance = 5

local function startBringMob()
    task.spawn(function()
        while bringMobEnabled do
            task.wait(0.15)
            local player = Players.LocalPlayer
            local char = player.Character
            if not char then task.wait(1) continue end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end
            
            local rootPos = root.Position
            local lookVector = root.CFrame.LookVector
            
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") then
                    local hrp = v.HumanoidRootPart
                    local hum = v.Humanoid
                    
                    if not Players:GetPlayerFromCharacter(v) and hum.Health > 0 then
                        local dist = (hrp.Position - rootPos).Magnitude
                        if dist <= bringRange then
                            local targetPos = rootPos + lookVector * bringDistance
                            hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(targetPos), 0.6)
                        end
                    end
                end
            end
        end
    end)
end

-- ========== CÁC HÀM DI CHUYỂN ==========
local function moveTo(position)
    local player = Players.LocalPlayer
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(position)
    end
end

