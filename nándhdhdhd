-- ==================== MAIN LOOP ====================
-- Lưu vị trí trước đó để tính vận tốc (prediction)
local lastPositions = {}
local velocityCache = {}

RunService.RenderStepped:Connect(function(deltaTime)
    local localChar = player.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
    
    -- FOV Circle ở giữa màn hình
    if aimbotEnabled then
        local screenCenter = Camera.ViewportSize / 2
        fovCircle.Position = UDim2.new(0, screenCenter.X, 0, screenCenter.Y)
        fovCircle.Size = UDim2.new(0, aimbotFov * 2, 0, aimbotFov * 2)
        fovStroke.Color = aimColor
        fovCircle.Visible = true
    else
        fovCircle.Visible = false
    end
    
    -- ESP Update
    for plr, data in pairs(espObjects) do
        if not plr.Character or not data.hrp or not data.hrp.Parent then
            removeESP(plr)
            continue
        end
        
        if localHrp then
            local dist = (data.hrp.Position - localHrp.Position).Magnitude
            local inRange = dist <= espMaxDist
            
            if data.highlight and data.highlight.Parent then
                data.highlight.Enabled = showBox and espEnabled and inRange
            end
            if data.tracer and data.tracer.Parent then
                data.tracer.Enabled = showTracer and espEnabled and inRange
            end
            if data.nameLabel then
                data.nameLabel.Visible = showNames and espEnabled and inRange
            end
            if data.healthLabel then
                data.healthLabel.Visible = showHealth and espEnabled and inRange
            end
        end
        
        if data.hum and data.hum.Parent then
            data.healthLabel.Text = "♥ " .. math.floor(data.hum.Health)
        end
    end
    
    -- ==================== AIMBOT LOGIC (ĐÃ SỬA) ====================
    if not aimbotEnabled then return end
    
    local shouldAim = false
    if isMobile then
        shouldAim = mobileAimHeld or autoAimEnabled
    else
        shouldAim = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or autoAimEnabled
    end
    
    if not shouldAim then return end
    if not localHrp then return end
    
    local screenCenter = Camera.ViewportSize / 2
    local bestTarget = nil
    local bestDistFromCenter = math.huge
    local bestScreenPos = nil
    
    -- Cập nhật vận tốc cho prediction
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local currentPos = head.Position
                if lastPositions[plr] then
                    velocityCache[plr] = (currentPos - lastPositions[plr]) / math.max(deltaTime, 0.001)
                end
                lastPositions[plr] = currentPos
            end
        end
    end
    
    -- Tìm mục tiêu tốt nhất (gần tâm màn hình nhất)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        if aimIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then continue end
        
        local char = plr.Character
        if not char then continue end
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and localHrp then
            local worldDist = (hrp.Position - localHrp.Position).Magnitude
            if worldDist > aimbotMaxDist then continue end
        end
        
        -- Sử dụng prediction: nhắm vào vị trí tương lai của head
        local targetPosition = head.Position
        if velocityCache[plr] then
            local predictionTime = 0.1
            targetPosition = targetPosition + velocityCache[plr] * predictionTime
        end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPosition)
        if not onScreen then continue end
        
        local distFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        
        -- Ưu tiên mục tiêu gần tâm nhất
        if distFromCenter <= aimbotFov and distFromCenter < bestDistFromCenter then
            bestDistFromCenter = distFromCenter
            bestTarget = plr
            bestScreenPos = screenPos
        end
    end
    
    -- Nếu không tìm thấy player, thử tìm NPC/Bot
    if not bestTarget then
        for _, obj in ipairs(Workspace:GetChildren()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("Head") then
                local hum = obj.Humanoid
                local head = obj.Head
                
                if hum.Health <= 0 then continue end
                if isInLobby(obj) then continue end
                
                local hrp = obj:FindFirstChild("HumanoidRootPart")
                if hrp and localHrp then
                    local worldDist = (hrp.Position - localHrp.Position).Magnitude
                    if worldDist > aimbotMaxDist then continue end
                end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if not onScreen then continue end
                
                local distFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                
                if distFromCenter <= aimbotFov and distFromCenter < bestDistFromCenter then
                    bestDistFromCenter = distFromCenter
                    bestScreenPos = screenPos
                    bestTarget = {Character = obj, isNPC = true}
                end
            end
        end
    end
    
    if not bestTarget or not bestScreenPos then return end
    
    -- Lấy vị trí mục tiêu trên màn hình
    local targetScreenPos = Vector2.new(bestScreenPos.X, bestScreenPos.Y)
    local mouseLocation = UserInputService:GetMouseLocation()
    local delta = targetScreenPos - mouseLocation
    
    -- Áp dụng smoothness
    if isMobile then
        local targetHead = bestTarget.Character and bestTarget.Character:FindFirstChild("Head")
        if targetHead then
            local lookAt = CFrame.new(Camera.CFrame.Position, targetHead.Position)
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, 0.3)
        end
    else
        local smoothedDelta = delta * (1 - aimbotSmooth)
        
        -- Giới hạn tốc độ di chuyển chuột
        local maxMove = 50
        if smoothedDelta.Magnitude > maxMove then
            smoothedDelta = smoothedDelta.Unit * maxMove
        end
        
        mousemoverel(smoothedDelta.X, smoothedDelta.Y)
    end
end)

-- ==================== INSTANT KILL LOOP ====================
spawn(function()
    while true do
        task.wait(0.1)
        
        if not instantKillEnabled then
            if followConnection then 
                followConnection:Disconnect() 
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
            continue
        end
        
        -- Cập nhật danh sách mục tiêu
        updateAllTargets()
        
        if #allTargets == 0 then
            resetCamera()
            continue
        end
        
        -- Nếu đang có mục tiêu và mục tiêu còn hợp lệ, tiếp tục theo dõi
        if currentTarget and isValidTarget(currentTarget) then
            -- Vẫn đang theo dõi mục tiêu hiện tại
            continue
        end
        
        -- Tìm mục tiêu mới gần nhất
        local found = false
        for i = 1, #allTargets do
            local model = allTargets[i]
            
            if isValidTarget(model) then
                followTarget(model)
                currentIndex = i
                found = true
                break
            end
        end
        
        if not found then
            resetCamera()
        end
    end
end)

