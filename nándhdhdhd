-- ==================== ESP FUNCTIONS ====================
local function removeESP(plr)
    local data = espObjects[plr]
    if not data then return end
    if data.highlight and data.highlight.Parent then data.highlight:Destroy() end
    if data.billboard and data.billboard.Parent then data.billboard:Destroy() end
    if data.tracer and data.tracer.Parent then data.tracer:Destroy() end
    if data.attachment0 and data.attachment0.Parent then data.attachment0:Destroy() end
    if data.attachment1 and data.attachment1.Parent then data.attachment1:Destroy() end
    espObjects[plr] = nil
end

local function createESP(plr)
    if plr == player then return end
    if espIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then return end
    
    removeESP(plr)
    
    local char = plr.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not head or not hrp or not hum then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = char
    highlight.FillColor = espColor
    highlight.FillTransparency = 0.8
    highlight.OutlineColor = espColor
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = showBox and espEnabled
    highlight.Parent = char
    
    local bill = Instance.new("BillboardGui")
    bill.Name = "ESP_Bill"
    bill.Adornee = head
    bill.AlwaysOnTop = true
    bill.Size = UDim2.new(0, 100, 0, 40)
    bill.StudsOffset = Vector3.new(0, 2, 0)
    bill.Parent = playerGui
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = plr.DisplayName
    nameLabel.TextColor3 = espColor
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.TextStrokeTransparency = 0.4
    nameLabel.Visible = showNames
    nameLabel.Parent = bill
    
    local healthLabel = Instance.new("TextLabel")
    healthLabel.Size = UDim2.new(1, 0, 0.5, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.5, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.Text = "♥ " .. math.floor(hum.Health)
    healthLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    healthLabel.Font = Enum.Font.Code
    healthLabel.TextSize = 11
    healthLabel.Visible = showHealth
    healthLabel.Parent = bill
    
    local attachment0 = Instance.new("Attachment")
    attachment0.Parent = hrp
    
    local localHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local attachment1 = Instance.new("Attachment")
    attachment1.Parent = localHrp or hrp
    
    local tracer = Instance.new("Beam")
    tracer.Attachment0 = attachment0
    tracer.Attachment1 = attachment1
    tracer.Color = ColorSequence.new(espColor)
    tracer.Width0 = 0.1
    tracer.Width1 = 0.1
    tracer.Transparency = NumberSequence.new(0.4)
    tracer.Enabled = showTracer and espEnabled
    tracer.Parent = hrp
    
    espObjects[plr] = {
        highlight = highlight,
        billboard = bill,
        nameLabel = nameLabel,
        healthLabel = healthLabel,
        tracer = tracer,
        attachment0 = attachment0,
        attachment1 = attachment1,
        hrp = hrp,
        hum = hum
    }
end

function refreshAllESP()
    for plr in pairs(espObjects) do
        removeESP(plr)
    end
    if not espEnabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local sameTeam = false
            if espIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then
                sameTeam = true
            end
            if not sameTeam then
                createESP(plr)
            end
        end
    end
end

-- ==================== INSTANT KILL FUNCTIONS ====================
local function isTargetAlive(model)
    return model and model:FindFirstChild("HumanoidRootPart")
        and model:FindFirstChild("Humanoid")
        and model.Humanoid.Health > 0
end

local function isValidTarget(model)
    -- Phải còn sống
    if not isTargetAlive(model) then return false end
    
    -- Không phải bản thân
    if model == player.Character then return false end
    
    -- Kiểm tra xem có đang trong sảnh/phòng chờ không
    if isInLobby(model) then return false end
    
    -- Nếu là người chơi thật, kiểm tra có trong lobby không
    if isRealPlayer(model) then
        if isInLobby(player.Character) then return false end
    end
    
    -- Không đánh đồng đội
    local plr = Players:GetPlayerFromCharacter(model)
    if plr and plr.Team and player.Team and plr.Team == player.Team then
        return false
    end
    
    return true
end

local function updateAllTargets()
    allTargets = {}
    local localChar = player.Character
    
    -- Thêm tất cả người chơi thật (không trong sảnh)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local char = plr.Character
            -- Chỉ thêm nếu KHÔNG ở trong sảnh
            if not isInLobby(char) then
                table.insert(allTargets, char)
            end
        end
    end
    
    -- Thêm tất cả bot/NPC (không trong sảnh)
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("Model")
            and obj:FindFirstChild("Humanoid")
            and obj:FindFirstChild("HumanoidRootPart")
            and not isRealPlayer(obj)
            and not isInLobby(obj) then -- Bỏ qua nếu ở sảnh
            
            -- Kiểm tra các loại bot phổ biến
            local validBot = false
            local botNames = {"Astration", "Bot", "Dummy", "NPC", "Zombie", "Enemy", "Target", "Training"}
            
            for _, name in ipairs(botNames) do
                if obj.Name:find(name) then
                    validBot = true
                    break
                end
            end
            
            -- Thêm cả các model có Humanoid mà không cần check tên cụ thể
            if validBot or obj:FindFirstChild("Humanoid").Health > 0 then
                table.insert(allTargets, obj)
            end
        end
    end
    
    -- Sắp xếp theo khoảng cách gần nhất
    if localChar and localChar:FindFirstChild("HumanoidRootPart") then
        local localPos = localChar.HumanoidRootPart.Position
        table.sort(allTargets, function(a, b)
            local hrpA = a:FindFirstChild("HumanoidRootPart")
            local hrpB = b:FindFirstChild("HumanoidRootPart")
            if not hrpA or not hrpB then return false end
            return (hrpA.Position - localPos).Magnitude < (hrpB.Position - localPos).Magnitude
        end)
    end
end

local function resetCamera()
    Camera.CameraType = Enum.CameraType.Custom
end

local function attackTarget()
    local currentTime = tick()
    if currentTime - lastAttackTime < 0.3 then return end -- Giới hạn tốc độ đánh
    
    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
    
    if tool then
        -- Kích hoạt tool để đánh
        pcall(function()
            tool:Activate()
            task.wait(0.1)
            tool:Deactivate()
        end)
    else
        -- Nếu không có tool, dùng click để đấm
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end)
    end
    
    lastAttackTime = currentTime
end

local function followTarget(model)
    if followConnection then 
        followConnection:Disconnect() 
    end
    
    currentTarget = model
    Camera.CameraType = Enum.CameraType.Scriptable
    
    followConnection = RunService.Heartbeat:Connect(function()
        -- Kiểm tra nếu Instant Kill bị tắt
        if not instantKillEnabled then
            if followConnection then followConnection:Disconnect() end
            followConnection = nil
            currentTarget = nil
            resetCamera()
            return
        end
        
        -- Kiểm tra mục tiêu còn hợp lệ không
        if not isValidTarget(model) then
            if followConnection then followConnection:Disconnect() end
            followConnection = nil
            currentTarget = nil
            resetCamera()
            return
        end
        
        local targetHRP = model:FindFirstChild("HumanoidRootPart")
        local targetHead = model:FindFirstChild("Head")
        local targetHum = model:FindFirstChild("Humanoid")
        local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        local myHead = player.Character and player.Character:FindFirstChild("Head")
        
        if not targetHRP or not myHRP then return end
        
        -- Bật noclip để đi xuyên tường
        myHRP.CanCollide = false
        
        -- === TELEPORT NGAY PHÍA SAU MỤC TIÊU ===
        local targetPos = targetHRP.Position
        local targetVelocity = targetHRP.Velocity
        
        -- Dự đoán vị trí tương lai của mục tiêu (nếu đang di chuyển)
        local predictionTime = 0.15
        local predictedPos = targetPos + (targetVelocity * predictionTime)
        
        -- Lấy hướng nhìn của mục tiêu
        local lookVector
        if targetHRP then
            lookVector = targetHRP.CFrame.LookVector
        else
            lookVector = Vector3.new(0, 0, -1)
        end
        
        -- Đứng ngay sau lưng mục tiêu
        local behindPos = predictedPos + Vector3.new(0, HEIGHT_OFFSET, 0) - (lookVector * DISTANCE)
        
        -- Kiểm tra khoảng cách để teleport mượt hơn
        local currentDist = (myHRP.Position - behindPos).Magnitude
        
        -- Nếu quá xa (> 50 studs), teleport ngay lập tức
        if currentDist > 50 then
            myHRP.CFrame = CFrame.lookAt(behindPos, predictedPos)
        else
            -- Nếu gần, di chuyển mượt mà
            myHRP.Velocity = (behindPos - myHRP.Position) * 8
            myHRP.CFrame = CFrame.lookAt(myHRP.Position, predictedPos)
        end
        
        -- === TỰ ĐỘNG ĐÁNH KHI Ở GẦN ===
        if targetHum then
            local distToTarget = (myHRP.Position - targetPos).Magnitude
            
            -- Nếu đủ gần, tự động đánh
            if distToTarget <= DISTANCE + 3 then
                attackTarget()
            end
        end
        
        -- === CAMERA LOCK VÀO ĐẦU MỤC TIÊU ===
        if targetHead and myHead then
            local myEyePos = myHead.Position
            local targetLookPos = targetHead.Position
            Camera.CFrame = CFrame.lookAt(myEyePos, targetLookPos)
        elseif targetHRP and myHRP then
            local myEyePos = myHRP.Position + Vector3.new(0, 2, 0)
            local targetLookPos = targetHRP.Position + Vector3.new(0, 1.5, 0)
            Camera.CFrame = CFrame.lookAt(myEyePos, targetLookPos)
        end
    end)
end

