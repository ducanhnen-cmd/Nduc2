	local StatusSection = StatusTab:AddSection("Server Status")
	
	local TimePara = StatusSection:AddParagraph({ Title = "Time", Content = "" })
	local MirageStatus = StatusSection:AddParagraph({ Title = "Mirage Island", Content = "❌" })
	local KitsuneStatus = StatusSection:AddParagraph({ Title = "Kitsune Island", Content = "❌" })
	local FullMoonStatus = StatusSection:AddParagraph({ Title = "Full Moon", Content = "" })
	
	task.spawn(function()
		while task.wait(1) do
			pcall(function()
				local date = os.date("*t")
				local hour = (date.hour) % 24
				local ampm = hour < 12 and "AM" or "PM"
				local timezone = string.format("%02i:%02i:%02i %s", ((hour - 1) % 12) + 1, date.min, date.sec, ampm)
				local datetime = string.format("%02d/%02d/%04d", date.day, date.month, date.year)
				TimePara:SetDesc(datetime .. " - " .. timezone)
				
				if workspace._WorldOrigin.Locations:FindFirstChild('Mirage Island') then
					MirageStatus:SetDesc("✅ Active")
				else
					MirageStatus:SetDesc("❌ Not Found")
				end
				
				if workspace.Map:FindFirstChild("KitsuneIsland") then
					KitsuneStatus:SetDesc("✅ Active")
				else
					KitsuneStatus:SetDesc("❌ Not Found")
				end
				
				local moonId = Lighting.Sky and Lighting.Sky.MoonTextureId or ""
				if moonId == "http://www.roblox.com/asset/?id=9709149431" then
					FullMoonStatus:SetDesc("🌕 Full Moon Active")
				else
					FullMoonStatus:SetDesc("🌑 Not Full Moon")
				end
			end)
		end
	end)
	
