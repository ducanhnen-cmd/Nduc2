	-- Auto Level Farm
	task.spawn(function()
		while task.wait(0.5) do
			if _G.Level and _G.StartFarm then
				pcall(function()
					local Q = QuestNeta()
					if not Q then return end
					
					if not plr.PlayerGui.Main.Quest.Visible then
						_tp(Q[6])
						if (plr.Character.HumanoidRootPart.Position - Q[6].Position).Magnitude <= 50 then
							task.wait(1.9)
							replicated.Remotes.CommF_:InvokeServer("StartQuest", Q[3], Q[2])
						end
						return
					end
					
					local mob = GetConnectionEnemies(Q[1])
					if mob and mob:FindFirstChild("HumanoidRootPart") then
						_tp(mob.HumanoidRootPart.CFrame * CFrame.new(0, _G.MobHeight, 0))
						EquipWeapon(_G.SelectWeapon)
						if G and G.Kill then
							G.Kill(mob, true)
						end
					else
						_tp(Q[4])
					end
				end)
			end
		end
	end)
	
